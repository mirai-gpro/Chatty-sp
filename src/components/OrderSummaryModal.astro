---
// OrderSummaryModal.astro - 注文一覧モーダル（注文サポートモード用）
---

<div class="order-modal-overlay hidden" id="orderModalOverlay">
  <div class="order-modal">
    <div class="order-modal-header">
      <h2>📋 ご注文内容</h2>
      <button class="order-modal-close" id="orderModalClose">&times;</button>
    </div>
    <div class="order-modal-body" id="orderModalBody">
      <p class="order-empty">まだ注文がありません</p>
    </div>
    <div class="order-modal-footer" id="orderModalFooter">
      <div class="order-total">
        <span>合計</span>
        <span class="order-total-price" id="orderTotalPrice">¥0</span>
      </div>
    </div>
  </div>
</div>

<style>
  .order-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 20000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.3s;
  }
  .order-modal-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .order-modal {
    background: white;
    border-radius: 20px;
    width: 90%;
    max-width: 480px;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    transform: scale(1);
    transition: transform 0.3s;
  }
  .order-modal-overlay.hidden .order-modal {
    transform: scale(0.9);
  }

  .order-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1px solid #e5e7eb;
  }
  .order-modal-header h2 {
    font-size: 18px;
    font-weight: 700;
    color: #1f2937;
    margin: 0;
  }
  .order-modal-close {
    background: none;
    border: none;
    font-size: 28px;
    color: #9ca3af;
    cursor: pointer;
    padding: 0 4px;
    line-height: 1;
  }
  .order-modal-close:hover {
    color: #1f2937;
  }

  .order-modal-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
  }
  .order-empty {
    text-align: center;
    color: #9ca3af;
    padding: 40px 0;
    font-size: 14px;
  }

  :global(.order-item) {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid #f3f4f6;
  }
  :global(.order-item:last-child) {
    border-bottom: none;
  }
  :global(.order-item-image) {
    width: 56px;
    height: 56px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    background: #f3f4f6;
  }
  :global(.order-item-image img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  :global(.order-item-info) {
    flex: 1;
    min-width: 0;
  }
  :global(.order-item-name) {
    font-size: 14px;
    font-weight: 600;
    color: #1f2937;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(.order-item-qty) {
    font-size: 12px;
    color: #6b7280;
    margin-top: 2px;
  }
  :global(.order-item-subtotal) {
    font-size: 15px;
    font-weight: 700;
    color: #dc2626;
    flex-shrink: 0;
  }

  .order-modal-footer {
    padding: 16px 20px;
    border-top: 2px solid #e5e7eb;
  }
  .order-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 18px;
    font-weight: 700;
    color: #1f2937;
  }
  .order-total-price {
    font-size: 24px;
    color: #dc2626;
  }
</style>
